flowchart LR

    %% ══════════════════════════════════════════════════════════════════════
    %% ENTRY — Authentication
    %% ══════════════════════════════════════════════════════════════════════
    START([▶ Start]) --> LOGIN[index.php\nLogin Page]
    LOGIN -. Forgot Password .-> FP[forgot-password.php\nReset Placeholder]
    LOGIN --> AUTH{Credentials\nValid?}
    AUTH -- No  --> ERR[Show Error] --> LOGIN
    AUTH -- Yes --> SESSION[Set Session\nuser_id + role]
    SESSION --> LOG_IN[Log Activity: LOGIN]
    LOG_IN --> ROLE{User Role?}

    ROLE -- admin --> ADMIN_DASH([admin/dashboard.php\nAdmin Home])
    ROLE -- user  --> USER_DASH([user/dashboard.php\nUser Home])

    %% ══════════════════════════════════════════════════════════════════════
    %% USER SIDE
    %% ══════════════════════════════════════════════════════════════════════
    subgraph USER ["USER SIDE"]
        direction TB

        subgraph U_INV_SUB ["Browse Inventory"]
            direction TB
            U_INV[user/inventory.php]
            U_INV --> U_FILT[Filter by campus / category]
            U_FILT --> U_ITEM_VIEW[View Item Details + QR Code]
        end

        subgraph U_REQ_SUB ["Submit Request"]
            direction TB
            U_REQ[user/requests.php]
            U_REQ --> CART[Build Cart\nclient-side JS]
            CART --> RT{Request Type?}
            RT -- Borrow  --> BF[Item + Return Date\nQty + Urgency + Reason]
            RT -- Item    --> IF2[Description + Qty\nUrgency + Reason]
            RT -- Service --> SF[Item + Service Type\nDescription + Urgency]
            BF  --> UPL[Upload Approval Letter\nPDF / JPG / PNG max 5 MB]
            IF2 --> UPL
            SF  --> UPL
            UPL --> FVAL{File Valid?}
            FVAL -- No  --> FERR[Validation Error] --> UPL
            FVAL -- Yes --> FSTORE[Save to assets/uploads/approval_letters/]
            FSTORE --> REQ_PEND[/Request Created\nStatus: pending/]
        end

        subgraph U_REC_SUB ["My Records — 3 Tabs"]
            direction TB
            U_REC[user/borrow-records.php]
            U_REC --> TAB_B[Borrow Records\nactive / returned / overdue]
            U_REC --> TAB_I[Item Requests\npending / approved / disapproved]
            U_REC --> TAB_S[Service Requests\npending / approved / disapproved]
            TAB_B --> PRINT_B[Print]
            TAB_I --> PRINT_I[Print]
            TAB_S --> PRINT_S[Print]
        end

        subgraph U_SET_SUB ["User Settings"]
            direction TB
            U_SET[user/settings.php]
            U_SET --> USET_ACT{Action}
            USET_ACT -- Update Profile  --> PROF_SAVE[Save name / phone]
            USET_ACT -- Change Password --> CUR_CHK{Current Password\nCorrect?}
            CUR_CHK -- Yes --> NEW_PWD[BCrypt-hash and Save]
            CUR_CHK -- No  --> PWD_ERR[Show Error]
        end

        USER_DASH_U([user/dashboard.php])
        USER_DASH_U --> U_INV_SUB
        USER_DASH_U --> U_REQ_SUB
        USER_DASH_U --> U_REC_SUB
        USER_DASH_U --> U_SET_SUB
    end

    USER_DASH --> USER_DASH_U

    %% ══════════════════════════════════════════════════════════════════════
    %% ADMIN SIDE
    %% ══════════════════════════════════════════════════════════════════════
    subgraph ADMIN ["ADMIN SIDE"]
        direction TB

        subgraph A_INV_SUB ["Inventory Management"]
            direction TB
            A_INV[admin/inventory.php]
            A_INV --> INV_ACT{Action}
            INV_ACT -- Add Item    --> ADD_ITEM[Create Record]
            ADD_ITEM --> GEN_QR[Generate per-unit QR codes\nQR-XXX-U01 to -UNN\nassets/qrcodes/]
            INV_ACT -- Edit        --> EDIT_ITEM[Update status / condition / location]
            INV_ACT -- Delete      --> DEL_ITEM[Remove record]
            INV_ACT -- Set Status  --> STAT_UPD[available / borrowed\nmaintenance / disposed]
            A_CAM[admin/inventory-campus.php\nCampus-Filtered View]
            A_CAM --> CAM_FILT[Filter items by campus_id]
        end

        subgraph A_REQ_SUB ["Request Management"]
            direction TB
            A_REQ[admin/requests.php]
            A_REQ --> REQ_FLT[Filter: type / status / urgency / campus]
            REQ_FLT --> VIEW_REQ[View Request and Approval Letter]
            VIEW_REQ --> DEC{Admin Decision}
            DEC -- Disapprove --> DISAPP[/Status: disapproved\nLog: DISAPPROVE/]
            DEC -- Approve    --> APPROV[/Status: approved\nLog: APPROVE/]
        end

        subgraph A_USR_SUB ["User Management"]
            direction TB
            A_USR[admin/users.php]
            A_USR --> USR_ACT{Action}
            USR_ACT -- View Profile        --> VIEW_USR[User info + borrow history]
            USR_ACT -- Activate/Deactivate --> TOGGLE[Toggle is_active]
            USR_ACT -- Assign Campus       --> ASSIGN[Set campus_id + college_id]
        end

        subgraph A_ANA_SUB ["Analytics"]
            direction TB
            A_ANA[admin/analytics.php]
            A_ANA --> CHARTS[Requests over time\nInventory status dist.\nTop items / Campus activity\nOverdue rate]
        end

        subgraph A_REP_SUB ["Reports"]
            direction TB
            A_REP[admin/reports.php]
            A_REP --> REP_TYPE{Report Type}
            REP_TYPE -- Inventory    --> R_INV[By campus / category / status]
            REP_TYPE -- Requests     --> R_REQ[By date range]
            REP_TYPE -- Borrow       --> R_BOR[With overdue flag]
            REP_TYPE -- Activity Log --> R_ACT[User action history]
            R_INV --> RPRINT[Print / Export]
            R_REQ --> RPRINT
            R_BOR --> RPRINT
            R_ACT --> RPRINT
        end

        subgraph A_SET_SUB ["Admin Settings"]
            direction TB
            A_SET[admin/settings.php]
            A_SET --> ASET_ACT{Action}
            ASET_ACT -- System Name/Email --> SYS_SAVE[Save system config]
            ASET_ACT -- Campus Config     --> CAM_CFG[Update campus list]
        end

        ADMIN_DASH_A([admin/dashboard.php])
        ADMIN_DASH_A --> A_INV_SUB
        ADMIN_DASH_A --> A_REQ_SUB
        ADMIN_DASH_A --> A_USR_SUB
        ADMIN_DASH_A --> A_ANA_SUB
        ADMIN_DASH_A --> A_REP_SUB
        ADMIN_DASH_A --> A_SET_SUB
    end

    ADMIN_DASH --> ADMIN_DASH_A

    %% ══════════════════════════════════════════════════════════════════════
    %% REQUEST LIFECYCLE
    %% ══════════════════════════════════════════════════════════════════════
    subgraph LIFECYCLE ["REQUEST LIFECYCLE"]
        direction TB

        APPROV_TYPE{Approved\nRequest Type?}

        subgraph BORROW_FLOW ["Borrow Flow"]
            direction TB
            BRCV{Receiving Method}
            BRCV -- Delivery --> EMAIL_D[Email: Out for Delivery]
            BRCV -- Pickup   --> EMAIL_P[Email: Ready for Pickup]
            EMAIL_D --> BR_RECV[User Receives Item]
            EMAIL_P --> BR_RECV
            BR_RECV --> BR_ACT[/Borrow Record: active\nInventory: borrowed/]
            BR_ACT --> IN_USE[Item In Use]
            IN_USE --> OVR{Past Return Date?}
            OVR -- Yes --> OVR_FLAG[/Borrow Record: overdue/]
            OVR -- No  --> IN_USE
            IN_USE --> RTN[Admin logs return]
            RTN --> BR_DONE[/Borrow Record: returned\nInventory: available/]
        end

        subgraph ITEM_FLOW ["Item Procurement Flow"]
            direction TB
            DISPATCH[Admin Dispatches Items\nQR codes printed per unit]
            DISPATCH --> EMAIL_IT[Email: Out for Delivery]
            EMAIL_IT --> MOB[Mobile App - planned\nUser scans unit QR codes]
            MOB --> SCAN_CHK{All Units Scanned?}
            SCAN_CHK -- No  --> MOB
            SCAN_CHK -- Yes --> ITEMDEL[/Status: delivered/]
        end

        subgraph SVC_FLOW ["Service Request Flow"]
            direction TB
            MAINT[Maintenance team\nscheduled and dispatched]
            MAINT --> SVC_DONE[/Service complete\nStatus: delivered\nInventory updated/]
        end

        APPROV_TYPE -- Borrow  --> BRCV
        APPROV_TYPE -- Item    --> DISPATCH
        APPROV_TYPE -- Service --> MAINT
    end

    %% ══════════════════════════════════════════════════════════════════════
    %% CROSS-SECTION CONNECTIONS
    %% ══════════════════════════════════════════════════════════════════════
    REQ_PEND --> A_REQ_SUB
    APPROV   --> APPROV_TYPE
    DISAPP   --> NOTIF_D[User sees: Disapproved\nin My Records]
    BR_DONE  --> U_REC_SUB
    ITEMDEL  --> U_REC_SUB
    SVC_DONE --> U_REC_SUB

    %% ══════════════════════════════════════════════════════════════════════
    %% LOGOUT
    %% ══════════════════════════════════════════════════════════════════════
    USER_DASH  --> LOGOUT[logout.php\nDestroy session / Log: LOGOUT]
    ADMIN_DASH --> LOGOUT
    LOGOUT     --> LOGIN

    %% ══════════════════════════════════════════════════════════════════════
    %% STYLES
    %% ══════════════════════════════════════════════════════════════════════
    style ADMIN_DASH   fill:#1e3a5f,color:#fff,stroke:#0f2341
    style USER_DASH    fill:#1e3a5f,color:#fff,stroke:#0f2341
    style ADMIN_DASH_A fill:#1e3a5f,color:#fff,stroke:#0f2341
    style USER_DASH_U  fill:#1e3a5f,color:#fff,stroke:#0f2341
    style REQ_PEND     fill:#ffc107,color:#000,stroke:#e0a800
    style APPROV       fill:#20c997,color:#fff,stroke:#1aa37a
    style DISAPP       fill:#dc3545,color:#fff,stroke:#b02a37
    style BR_ACT       fill:#0dcaf0,color:#000,stroke:#0baccc
    style OVR_FLAG     fill:#dc3545,color:#fff,stroke:#b02a37
    style BR_DONE      fill:#198754,color:#fff,stroke:#157347
    style ITEMDEL      fill:#198754,color:#fff,stroke:#157347
    style SVC_DONE     fill:#198754,color:#fff,stroke:#157347
    style MOB          fill:#6f42c1,color:#fff,stroke:#5a359a
    style FP           fill:#6c757d,color:#fff,stroke:#5a6268

