erDiagram

    %% ── Core lookup tables ──────────────────────────────────────────────────

    CAMPUSES {
        int     id          PK
        string  name
        string  location
        string  description
    }

    COLLEGES_OFFICES {
        string  code        PK  "e.g. CCS, OUP"
        string  name
        enum    type        "college | office"
        int     campus_id   FK  "only campus_id = 1 (Main)"
    }

    BORROW_CATALOG {
        int     id          PK
        string  name
        string  category    "Electronics | Furniture | Equipment | Supplies | Appliances | Safety"
        string  description
    }
    %% ── Admin entities ──────────────────────────────────────────────────

    ADMINS {
        int      id               PK  "same id as USERS.id"
        int      user_id          FK  "references USERS.id"
        int      managed_campus_id FK  "nullable — campus admin oversees"
        bool     can_manage_users     "permission flag"
        bool     can_manage_inventory "permission flag"
        bool     can_view_analytics   "permission flag"
        bool     can_view_reports     "permission flag"
        datetime last_login
    }

    ADMIN_SETTINGS {
        int      id              PK
        string   system_name           "e.g. ManageMo"
        string   system_email          "no-reply@psu.edu.ph"
        string   institution_name      "Pampanga State University"
        string   address
        int      default_campus_id FK
        int      items_per_page        "pagination size"
        bool     email_notifications   "global toggle"
        datetime updated_at
        int      updated_by    FK      "admin user id"
    }
    %% ── User management ─────────────────────────────────────────────────────

    USERS {
        int      id          PK
        string   email
        string   password              "BCrypt hash"
        string   full_name
        enum     role        "admin | user"
        int      campus_id   FK
        string   college_id  FK        "nullable — Main Campus only"
        string   phone
        bool     is_active
        datetime created_at
        datetime updated_at
    }

    %% ── Inventory ───────────────────────────────────────────────────────────

    INVENTORY {
        int      id              PK
        string   qr_code_id              "Base QR: QR-XXXXXXXXXX"
        string   item_name
        string   category
        string   description
        int      campus_id       FK
        string   college_id      FK      "nullable"
        int      quantity
        enum     status          "available | borrowed | maintenance | damaged | disposed"
        string   location
        date     purchase_date
        decimal  cost
        enum     condition       "excellent | good | fair | poor"
        datetime created_at
    }

    INVENTORY_QR_UNITS {
        string   unit_qr_code   PK  "QR-XXXXXXXXXX-U01 ... -UNN"
        int      inventory_id   FK
        int      unit_number
    }

    %% ── Requests ────────────────────────────────────────────────────────────

    APPROVAL_LETTERS {
        int      id              PK
        int      request_id      FK
        string   original_name
        string   stored_filename
        string   mime_type       "application/pdf | image/jpeg | image/png"
        int      file_size_bytes
        string   file_path       "assets/uploads/approval_letters/"
        datetime uploaded_at
    }

    REQUESTS {
        int      id                   PK
        string   request_number               "REQ-NNNNN"
        int      user_id              FK
        int      inventory_id         FK      "nullable — not used for item requests"
        enum     request_type         "borrow | item | service"
        enum     urgency              "low | medium | high | critical"
        string   receiving_method     "delivery | pickup"
        string   reason_for_request
        string   service_description
        date     expected_return_date         "borrow only"
        int      quantity_requested
        enum     status               "pending | approved | disapproved | delivered | returned"
        enum     delivery_status      "out_for_delivery | delivered | null"
        string   approval_notes               "admin notes on decision"
        int      approved_by          FK      "admin user id — nullable"
        datetime approved_at
        datetime created_at
        datetime updated_at
    }

    %% ── Borrow tracking ─────────────────────────────────────────────────────

    BORROW_RECORDS {
        int      id                   PK
        int      inventory_id         FK
        int      user_id              FK
        int      request_id           FK
        date     borrow_date
        date     expected_return_date
        date     actual_return_date           "null until returned"
        enum     status               "active | returned | overdue"
        string   notes
        datetime created_at
    }

    %% ── Audit / admin ───────────────────────────────────────────────────────

    ACTIVITY_LOGS {
        int      id           PK
        int      user_id      FK
        string   action               "LOGIN | LOGOUT | APPROVE | DISAPPROVE | ADD | EDIT | DELETE"
        string   description
        string   table_name           "nullable — affected table"
        int      record_id            "nullable — affected row id"
        datetime created_at
    }

    %% ════════════════════════════════════════════════════════════════════════
    %% RELATIONSHIPS
    %% ════════════════════════════════════════════════════════════════════════

    %% Campus relations
    CAMPUSES           ||--o{ USERS              : "belongs to"
    CAMPUSES           ||--o{ INVENTORY          : "located in"
    CAMPUSES           ||--o{ COLLEGES_OFFICES   : "has"

    %% Admin relations
    USERS              ||--o| ADMINS             : "has admin profile"
    ADMINS             }o--o| CAMPUSES           : "oversees"
    ADMINS             ||--o{ ADMIN_SETTINGS     : "configures"
    ADMINS             ||--o{ REQUESTS           : "approves / disapproves"
    ADMINS             ||--o{ ACTIVITY_LOGS      : "recorded in"

    %% User relations
    USERS              }o--o| COLLEGES_OFFICES   : "member of"
    USERS              ||--o{ REQUESTS           : "submits"
    USERS              ||--o{ REQUESTS           : "approves (admin)"
    USERS              ||--o{ BORROW_RECORDS     : "has"
    USERS              ||--o{ ACTIVITY_LOGS      : "generates"

    %% Inventory relations
    INVENTORY          ||--o{ REQUESTS           : "referenced in"
    INVENTORY          ||--o{ BORROW_RECORDS     : "tracked via"
    INVENTORY          ||--o{ INVENTORY_QR_UNITS : "has units"

    %% Borrow catalog
    BORROW_CATALOG     ||--o{ REQUESTS           : "suggested for"

    %% Request relations
    REQUESTS           ||--o| BORROW_RECORDS     : "creates"
    REQUESTS           ||--o| APPROVAL_LETTERS   : "has"
