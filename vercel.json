{
  "buildCommand": "echo 'Building ManageMo'",
  "routes": [
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/database/(.*)", "dest": "/database/$1" },
    { "src": "/(.*\\.php)$", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
