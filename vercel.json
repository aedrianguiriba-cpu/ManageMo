{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "admin/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "user/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*\\.php)", "dest": "/$1" },
    { "src": "/admin/(.*\\.php)", "dest": "/admin/$1" },
    { "src": "/user/(.*\\.php)", "dest": "/user/$1" },
    { "src": "/(.*)", "dest": "/index.php" }
  ],
  "buildCommand": "npm run build || true",
  "outputDirectory": "public",
  "env": {
    "PHP_DISPLAY_ERRORS": "1"
  }
}
