{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "admin/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "user/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "config/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "includes/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "lib/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
